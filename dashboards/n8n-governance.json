          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  w.name AS workflow,\n  COALESCE(p.name, '(no project)') AS project,\n  w.\"updatedAt\" AS last_edited,\n  COUNT(e.*) AS executions_7d,\n  COUNT(e.*) FILTER (WHERE e.status = 'success') AS successes_7d,\n  COUNT(e.*) FILTER (WHERE e.status IN ('error','crashed')) AS failures_7d,\n  MAX(e.\"startedAt\") AS last_execution\nFROM workflow_entity w\nLEFT JOIN execution_entity e ON e.\"workflowId\" = w.id\n  AND e.\"startedAt\" > NOW() - INTERVAL '7 days'\n  AND e.\"deletedAt\" IS NULL\nLEFT JOIN shared_workflow sw ON sw.\"workflowId\" = w.id AND sw.role = 'workflow:owner'\nLEFT JOIN project p ON p.id = sw.\"projectId\"\nWHERE w.active = true AND w.\"isArchived\" = false\n  AND ('__all__' IN (${workflow:singlequote}) OR w.id IN (${workflow:singlequote}))\n  AND ('__all__' IN (${project:singlequote}) OR sw.\"projectId\" IN (${project:singlequote}))\nGROUP BY w.id, w.name, p.name, w.\"updatedAt\"\nHAVING COUNT(e.*) FILTER (WHERE e.status = 'success') = 0\nORDER BY failures_7d DESC, last_execution DESC NULLS LAST\nLIMIT 50;",
