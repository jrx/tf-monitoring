      "pluginVersion": "12.3.0",
      "targets": [
        {
          "dataset": "n8n_data",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "n8n-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Executions this month\"\nFROM execution_entity e\nJOIN workflow_entity w ON w.id = e.\"workflowId\"\nLEFT JOIN shared_workflow sw ON sw.\"workflowId\" = w.id AND sw.role = 'workflow:owner'\nLEFT JOIN project p ON p.id = sw.\"projectId\"\nWHERE e.\"startedAt\" >= DATE_TRUNC('month', NOW())\n  AND e.\"deletedAt\" IS NULL\n  AND ('__all__' IN (${workflow:singlequote}) OR w.id IN (${workflow:singlequote}))\n  AND ('__all__' IN (${project:singlequote}) OR sw.\"projectId\" IN (${project:singlequote}));",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Executions this month",
      "type": "stat"
    },
