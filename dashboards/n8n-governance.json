          "rawSql": "SELECT\n  ROUND(100.0 * COUNT(*) / NULLIF(${quota:raw}, 0), 2) AS \"% of quota\"\nFROM execution_entity e\nJOIN workflow_entity w ON w.id = e.\"workflowId\"\nLEFT JOIN shared_workflow sw ON sw.\"workflowId\" = w.id AND sw.role = 'workflow:owner'\nLEFT JOIN project p ON p.id = sw.\"projectId\"\nWHERE e.\"startedAt\" >= DATE_TRUNC('month', NOW())\n  AND e.\"deletedAt\" IS NULL\n  AND ('__all__' IN (${workflow:singlequote}) OR w.id IN (${workflow:singlequote}))\n  AND ('__all__' IN (${project:singlequote}) OR sw.\"projectId\" IN (${project:singlequote}));",
