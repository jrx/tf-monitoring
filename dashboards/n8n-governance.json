      "pluginVersion": "12.3.0",
      "targets": [
        {
          "dataset": "n8n_data",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "n8n-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  w.name AS workflow,\n  COALESCE(p.name, '(no project)') AS project,\n  MIN(e.\"startedAt\") AS first_execution,\n  MAX(e.\"startedAt\") AS last_execution,\n  w.\"updatedAt\" AS last_edited,\n  EXTRACT(DAY FROM NOW() - w.\"updatedAt\")::int AS days_since_edit,\n  COUNT(*) AS total_executions\nFROM workflow_entity w\nJOIN execution_entity e ON e.\"workflowId\" = w.id\nLEFT JOIN shared_workflow sw ON sw.\"workflowId\" = w.id AND sw.role = 'workflow:owner'\nLEFT JOIN project p ON p.id = sw.\"projectId\"\nWHERE w.active = true AND w.\"isArchived\" = false\n  AND e.\"deletedAt\" IS NULL\n  AND ('__all__' IN (${workflow:singlequote}) OR w.id IN (${workflow:singlequote}))\n  AND ('__all__' IN (${project:singlequote}) OR sw.\"projectId\" IN (${project:singlequote}))\nGROUP BY w.id, w.name, p.name, w.\"updatedAt\"\nHAVING MIN(e.\"startedAt\") < NOW() - INTERVAL '30 days'\n   AND MAX(e.\"startedAt\") > NOW() - INTERVAL '7 days'\n   AND w.\"updatedAt\" < NOW() - INTERVAL '30 days'\nORDER BY days_since_edit DESC, total_executions DESC\nLIMIT 50;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Zombie workflows (active >30d, not edited >30d)",
      "type": "table"
    },
