{
  "uid": "n8n-audit-events",
  "title": "n8n audit events",
  "description": "Enterprise Log Streaming: audit-event view sourced from Loki tenant_id=1, label source=\"n8n-log-streaming\".",
  "tags": [
    "n8n",
    "audit",
    "loki",
    "log-streaming"
  ],
  "timezone": "browser",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "preload": false,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Audit summary",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total audit events",
      "description": "All n8n.audit.* events received in the selected time range.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({source=\"n8n-log-streaming\"} | json | eventName=~`n8n\\.audit\\..*` [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "transparent": true
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Distinct event types",
      "description": "Unique eventName values seen, e.g. n8n.audit.workflow.created.",
