    {
      "id": 11,
      "type": "table",
      "title": "Workflows by exec rate & error %",
      "description": "Per-workflow execution rate (Value #A, /s) and error rate (Value #B, %). Sorted by rate.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (n8n_workflow_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\"}[$__rate_interval]))",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "legendFormat": "",
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum by (n8n_workflow_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum by (n8n_workflow_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\"}[$__rate_interval])), 1e-9)",
          "refId": "B",
