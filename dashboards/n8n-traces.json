                "id": "unit",
                "value": "reqps"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Exec/s",
            "desc": true
          }
        ]
      },
      "transformations": [
