{
  "uid": "n8n-traces",
  "title": "n8n traces (RED metrics)",
  "description": "RED metrics (rate / errors / duration) derived from n8n's OpenTelemetry spans by the Jaeger spanmetrics connector and scraped into Prometheus. Reads the prometheus datasource. Empty until n8n tracing is enabled (n8n_otel_enabled = true in the n8n workspace). For individual trace search, use Explore \u2192 Jaeger.",
  "tags": [
    "n8n",
    "traces",
    "otel",
    "prometheus"
  ],
  "timezone": "browser",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(traces_span_metrics_calls_total, service_name)",
        "query": {
          "qryType": 1,
          "query": "label_values(traces_span_metrics_calls_total, service_name)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "skipUrlSync": false,
        "regex": ""
      },
      {
        "name": "workflow",
        "type": "query",
        "label": "Workflow",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\"}, n8n_workflow_name)",
        "query": {
          "qryType": 1,
          "query": "label_values(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\"}, n8n_workflow_name)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "sort": 1,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "skipUrlSync": false,
        "regex": ""
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "preload": false,
  "weekStart": "",
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Workflow execution traces \u2014 RED overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Exec rate",
      "description": "workflow.execute spans/sec across the selected workflows (the n8n execution rate as seen by tracing).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\"}[$__rate_interval]))",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "pluginVersion": "12.3.0",
      "transparent": true
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate",
      "description": "Percentage of workflow.execute spans with status_code=ERROR over the rate window.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 5,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum(rate(traces_span_metrics_calls_total{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\"}[$__rate_interval])), 1e-9)",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "pluginVersion": "12.3.0",
      "transparent": true
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 duration",
      "description": "95th-percentile workflow execution duration.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 10,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\", span_name=\"workflow.execute\", n8n_workflow_name=~\"$workflow\"}[$__rate_interval])))",
          "refId": "A",
          "editorMode": "code",
          "range": true,
